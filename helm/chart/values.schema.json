{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "declarative-agent-library-chart values [DALC-REQ-RAG-SCRAPERS-001] (draft + runtime v1)",
  "type": "object",
  "properties": {
    "replicaCount": { "type": "integer", "minimum": 1 },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string" }
      }
    },
    "systemPrompt": {
      "type": "string",
      "description": "Supervisor instructions; rendered into ConfigMap as HOSTED_AGENT_SYSTEM_PROMPT (root agent when subagents are configured)"
    },
    "chatModel": {
      "type": "string",
      "description": "Optional LangChain chat model id when subagents are non-empty (e.g. openai:gpt-4o-mini) → HOSTED_AGENT_CHAT_MODEL; requires provider package + credentials in the image"
    },
    "service": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "port": { "type": "integer" },
        "nodePort": { "type": ["integer", "null"] }
      }
    },
    "tools": {
      "type": "object",
      "description": "DRAFT — proposal shape; runtime ignores in v1",
      "properties": {
        "slack": {
          "type": "object",
          "properties": {
            "channels": { "type": "array", "items": { "type": "string" } },
            "searches": { "type": "array", "items": { "type": "string" } },
            "slackBotName": { "type": "string" },
            "slackBotId": { "type": "string" }
          }
        },
        "jira": {
          "type": "object",
          "properties": {
            "projects": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "key": { "type": "string" },
                  "scopes": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "create-issues",
                        "modify-issues",
                        "transition-issues"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "drive": { "type": "object" }
      }
    },
    "scrapers": {
      "type": "object",
      "description": "CronJob-backed scrapers under jira and slack; RAG deploys when any enabled job exists. Traceability: [DALC-REQ-RAG-SCRAPERS-003]",
      "properties": {
        "resources": { "type": "object" },
        "cursorStore": {
          "type": "object",
          "description": "Durable cursor backend for scraper incremental state. Traceability: [DALC-REQ-SCRAPER-CURSOR-003] [DALC-REQ-SCRAPER-CURSOR-004]",
          "properties": {
            "backend": {
              "type": "string",
              "enum": ["file", "postgres"],
              "description": "file keeps existing local cursor files; postgres enables DSN env wiring for scraper CronJobs. When postgres and scraper jobs exist, chart rendering fails unless postgresUrlSecretName or checkpoints.postgresUrl is set"
            },
            "postgresUrlSecretName": {
              "type": "string",
              "description": "Optional Secret name for scraper-specific Postgres DSN override"
            },
            "postgresUrlSecretKey": {
              "type": "string",
              "description": "Secret key containing the Postgres DSN (default: url)"
            }
          }
        },
        "ragService": {
          "type": "object",
          "description": "Managed RAG HTTP service (/v1/embed, /v1/query, /v1/relate); deployed only when an enabled scraper job exists",
          "properties": {
            "replicaCount": { "type": "integer", "minimum": 1 },
            "service": {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
              }
            },
            "resources": { "type": "object" }
          }
        },
        "jira": {
          "type": "object",
          "description": "Jira Cloud scraper jobs; each job mounts job.json (source=jira, query=JQL). Secrets via auth Secret refs only.",
          "properties": {
            "enabled": { "type": "boolean" },
            "siteUrl": { "type": "string" },
            "watermarkDir": { "type": "string" },
            "auth": {
              "type": "object",
              "properties": {
                "emailSecretName": { "type": "string" },
                "emailSecretKey": { "type": "string" },
                "tokenSecretName": { "type": "string" },
                "tokenSecretKey": { "type": "string" }
              }
            },
            "defaults": {
              "type": "object",
              "properties": {
                "maxIssuesPerRun": { "type": "integer", "minimum": 1 },
                "maxCommentsPerIssue": { "type": "integer", "minimum": 1 },
                "overlapMinutes": { "type": "integer", "minimum": 0 },
                "extraFields": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "jobs": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["schedule", "source", "query"],
                "properties": {
                  "enabled": { "type": "boolean" },
                  "schedule": { "type": "string", "minLength": 1 },
                  "scope": { "type": "string" },
                  "source": {
                    "type": "string",
                    "enum": ["jira"],
                    "description": "Must be jira; unknown sources cause the job to exit non-zero"
                  },
                  "query": {
                    "type": "string",
                    "minLength": 1,
                    "description": "JQL executed incrementally with an updated>= watermark when present"
                  }
                }
              }
            }
          }
        },
        "slack": {
          "type": "object",
          "description": "Slack scraper jobs (slack_search uses Real-time Search API + conversations.*; slack_channel uses conversations.history).",
          "properties": {
            "enabled": { "type": "boolean" },
            "stateDir": {
              "type": "string",
              "description": "Directory for channel-scrape cursors (empty PVC path in production)"
            },
            "auth": {
              "type": "object",
              "properties": {
                "botTokenSecretName": { "type": "string" },
                "botTokenSecretKey": { "type": "string" },
                "userTokenSecretName": { "type": "string" },
                "userTokenSecretKey": { "type": "string" }
              }
            },
            "defaults": { "type": "object" },
            "feedback": {
              "type": "object",
              "description": "Slack reaction → human feedback labels; maps to HOSTED_AGENT_SLACK_* and HOSTED_AGENT_LABEL_REGISTRY_JSON. Traceability: [DALC-REQ-CHART-RTV-003]",
              "properties": {
                "enabled": { "type": "boolean" },
                "emojiLabelMap": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "labelRegistry": {
                  "type": "object",
                  "description": "Feedback label taxonomy JSON for HOSTED_AGENT_LABEL_REGISTRY_JSON (not Kubernetes labels)"
                }
              }
            },
            "jobs": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["schedule", "source"],
                "properties": {
                  "enabled": { "type": "boolean" },
                  "schedule": { "type": "string", "minLength": 1 },
                  "scope": { "type": "string" },
                  "source": {
                    "type": "string",
                    "enum": ["slack_search", "slack_channel"]
                  },
                  "query": { "type": "string" },
                  "contextBeforeMinutes": { "type": "number", "minimum": 0 },
                  "contextAfterMinutes": { "type": "number", "minimum": 0 },
                  "conversationId": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "subagents": {
      "type": "array",
      "description": "Specialists exposed as LangChain tools on the root agent (name, description recommended, optional role metrics|rag|default, optional exposeAsTool)",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": {
            "type": "string",
            "description": "Recommended: tool schema / supervisor discovery text (LangChain subagents enumeration)"
          },
          "systemPrompt": { "type": "string" },
          "system_prompt": { "type": "string" },
          "role": { "type": "string" },
          "exposeAsTool": {
            "type": "boolean",
            "description": "When false, omit this subagent from the default tool list (metrics defaults to false unless set true)"
          },
          "scrapers": { "type": "array" },
          "tools": { "type": "array" }
        }
      }
    },
    "skills": {
      "type": "array",
      "description": "Skill catalog entries (name, prompt, optional extraTools)",
      "items": { "type": "object" }
    },
    "mcp": {
      "type": "object",
      "description": "Allowlisted in-process tools invoked via POST /api/v1/trigger (JSON tool + tool_arguments)",
      "properties": {
        "enabledTools": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "observability": {
      "type": "object",
      "description": "Kubernetes/Prometheus: scrape annotations, JSON logs, optional ServiceMonitor (Prometheus Operator CRD). Traceability: [DALC-REQ-O11Y-SCRAPE-004] [DALC-REQ-O11Y-SCRAPE-005] [DALC-REQ-O11Y-SCRAPE-006]",
      "properties": {
        "store": {
          "type": "string",
          "enum": ["memory", "postgres"],
          "description": "Where correlation/feedback/side-effects/span summaries live (maps to HOSTED_AGENT_OBSERVABILITY_STORE)."
        },
        "postgresUrl": {
          "type": "string",
          "description": "Plaintext Postgres URL for observability + checkpoint pool when no secret is used."
        },
        "postgresUrlSecret": {
          "type": "object",
          "description": "Alternative to postgresUrl / postgres.url: mount DSN from a Secret.",
          "properties": {
            "name": { "type": "string" },
            "key": { "type": "string" }
          }
        },
        "postgres": {
          "type": "object",
          "description": "Nested Postgres URL/secret and pool cap (see deployment template for precedence with checkpoints.postgresUrl).",
          "properties": {
            "url": { "type": "string" },
            "poolMax": { "type": "integer", "minimum": 1 },
            "urlSecret": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "key": { "type": "string" }
              }
            },
            "migrations": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "image": { "type": "string" }
              }
            }
          }
        },
        "prometheusAnnotations": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "structuredLogs": {
          "type": "object",
          "properties": {
            "json": { "type": "boolean" }
          }
        },
        "serviceMonitor": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "interval": { "type": "string" },
            "scrapeTimeout": { "type": "string" },
            "extraLabels": { "type": "object" }
          }
        }
      }
    },
    "checkpoints": {
      "type": "object",
      "description": "LangGraph checkpoint store; maps to HOSTED_AGENT_POSTGRES_URL (optional) and checkpoint env. Traceability: [DALC-REQ-CHART-RTV-001]",
      "properties": {
        "postgresUrl": { "type": "string" },
        "enabled": { "type": "boolean" },
        "backend": { "type": "string" }
      }
    },
    "wandb": {
      "type": "object",
      "description": "Weights & Biases tracing toggles. Traceability: [DALC-REQ-CHART-RTV-002]",
      "properties": {
        "enabled": { "type": "boolean" },
        "project": { "type": "string" },
        "entity": { "type": "string" }
      }
    },
    "presence": {
      "type": "object",
      "description": "Slack/Jira bot identity for the hosted agent (Secret refs). Traceability: [DALC-REQ-CHART-PRESENCE-001]",
      "properties": {
        "slack": {
          "type": "object",
          "properties": {
            "botUserId": {
              "type": "object",
              "description": "Slack bot user id (e.g. U…); maps to HOSTED_AGENT_SLACK_BOT_USER_ID when secretName is non-empty",
              "properties": {
                "secretName": { "type": "string" },
                "secretKey": { "type": "string" }
              }
            }
          }
        },
        "jira": {
          "type": "object",
          "properties": {
            "botAccountId": {
              "type": "object",
              "description": "Jira Cloud accountId for the automation user; maps to HOSTED_AGENT_JIRA_BOT_ACCOUNT_ID when secretName is non-empty",
              "properties": {
                "secretName": { "type": "string" },
                "secretKey": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "extraEnv": {
      "type": "array",
      "description": "Optional name/value env pairs on the agent container (e.g. HOSTED_AGENT_CHECKPOINT_STORE, WANDB_*)",
      "items": {
        "type": "object",
        "required": ["name", "value"],
        "properties": {
          "name": { "type": "string" },
          "value": { "type": "string" }
        }
      }
    },
    "resources": { "type": "object" }
  }
}
